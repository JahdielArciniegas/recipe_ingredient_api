{
  "openapi": "3.0.1",
  "info": {
    "title": "Recipe Ingredients API",
    "description": "API para gestionar recetas e ingredientes de cocina de manera eficiente",
    "contact": {
      "email": "arciniegasjahdiel@gmail.com"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://recipe-ingredient-api.vercel.app/api"
    }
  ],
  "tags": [
    {
      "name": "auth",
      "description": "Autenticación de los usuarios"
    },
    {
      "name": "ingredients",
      "description": "Operaciones acerca de los ingredientes"
    },
    {
      "name": "recipes",
      "description": "Operaciones acerca de las recetas"
    },
    {
      "name": "view",
      "description": "Vistas generales y consultas públicas"
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "tags": ["auth"],
        "summary": "Login de un usuario",
        "operationId": "login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login exitoso",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthResponse" }
              }
            }
          },
          "401": { "description": "Credenciales inválidas" }
        }
      }
    },
    "/auth/register": {
      "post": {
        "tags": ["auth"],
        "summary": "Registro de un usuario",
        "operationId": "register",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/User" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Usuario creado",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthResponse" }
              }
            }
          }
        }
      }
    },
    "/ingredients": {
      "get": {
        "tags": ["ingredients"],
        "summary": "Listar todos los ingredientes",
        "responses": {
          "200": {
            "description": "Listado exitoso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Ingredient" }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["ingredients"],
        "summary": "Crear un nuevo ingrediente",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Ingredient" }
            }
          }
        },
        "responses": {
          "201": { "description": "Ingrediente creado" },
          "401": { "description": "No autorizado" }
        }
      }
    },
    "/ingredients/{id}": {
      "get": {
        "tags": ["ingredients"],
        "summary": "Obtener un ingrediente por ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Ingredient" }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["ingredients"],
        "summary": "Actualizar ingrediente",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Ingredient" }
            }
          }
        },
        "responses": {
          "200": { "description": "Ingrediente actualizado" }
        }
      },
      "delete": {
        "tags": ["ingredients"],
        "summary": "Eliminar ingrediente",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Ingrediente eliminado" }
        }
      }
    },
    "/recipes": {
      "get": {
        "tags": ["recipes"],
        "summary": "Listar todas las recetas",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Recipe" }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["recipes"],
        "summary": "Crear una nueva receta",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Recipe" }
            }
          }
        },
        "responses": {
          "201": { "description": "Receta creada" }
        }
      }
    },
    "/recipes/{id}": {
      "get": {
        "tags": ["recipes"],
        "summary": "Obtener receta por ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Recipe" }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["recipes"],
        "summary": "Eliminar receta",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Receta eliminada" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "username": { "type": "string" },
          "email": { "type": "string" },
          "password": { "type": "string", "writeOnly": true }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "token": { "type": "string" },
          "user": { "$ref": "#/components/schemas/User" }
        }
      },
      "Ingredient": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "price": { "type": "number" },
          "unit": { "type": "string" },
          "amount": { "type": "number" }
        }
      },
      "Recipe": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "ingredients": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Ingredient" }
          }
        }
      }
    }
  }
}